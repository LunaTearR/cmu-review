# App
APP_PORT=8080
APP_NAME=cmu-review-backend
APP_ENV=production
APP_CORS_ALLOW_ORIGINS=<your-production-origin>
APP_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
APP_CORS_ALLOW_HEADERS=Origin,Content-Type,X-Request-ID

# Database
DATABASE_URL=<your-production-database-url>
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=300
